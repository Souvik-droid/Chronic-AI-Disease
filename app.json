{
  "expo": {
    "name": "ChronicCare AI",
    "slug": "chroniccare-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chroniccare",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14b8a6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chroniccare.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ChronicCare AI needs camera access to scan medical documents and QR codes from IoT devices.",
        "NSLocationWhenInUseUsageDescription": "ChronicCare AI needs location access for emergency services.",
        "NSBluetoothAlwaysUsageDescription": "ChronicCare AI needs Bluetooth to connect to medical IoT devices.",
        "NSBluetoothPeripheralUsageDescription": "ChronicCare AI needs Bluetooth to connect to medical IoT devices."
      }
    },
    "android": {
      "package": "com.chroniccare.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#14b8a6"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ChronicCare AI to access your camera to scan medical documents and IoT device QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
